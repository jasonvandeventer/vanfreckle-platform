<!-- ════════════════════════════════════════════════════════════════════════
     worker1 — worker + Longhorn replica on a PASSED-THROUGH SATA SSD (MX500).
     Drive placement (SMART 2026-06-13): MX500 → worker1 (healthiest drive on the
     least-disrupted node). Whole-device passthrough by-id.
     Substituted by define-vms.sh: __NAME__ __RAM_MIB__ __VCPUS__ __DISK_DIR__ __BRIDGE__ __SATA_BYID__
     🛑 __SATA_BYID__ TODO: real /dev/disk/by-id/ path is UNKNOWN until the drive is on an
        INTERNAL SATA port (USB-SATA bridge reports a different/unstable id — do NOT use it).
        After internal install:
          ls -l /dev/disk/by-id/ | grep -i 'ata-CT500MX500'
        and set WORKER1_SATA_BYID in cluster.env. define-vms.sh refuses to define worker1 until set.
     Note: no etcd on the worker, but system disk cache='none' kept for uniformity; the
     passthrough uses cache='none' io='native'.
     ════════════════════════════════════════════════════════════════════════ -->
<domain type='kvm'>
  <name>__NAME__</name>
  <memory unit='MiB'>__RAM_MIB__</memory>
  <vcpu placement='static'>__VCPUS__</vcpu>
  <os>
    <type arch='x86_64' machine='q35'>hvm</type>
    <loader readonly='yes' type='pflash'>/usr/share/qemu/ovmf-x64/OVMF_CODE-pure-efi.fd</loader>
    <nvram>/etc/libvirt/qemu/nvram/__NAME___VARS-pure-efi.fd</nvram>
    <boot dev='cdrom'/>
    <boot dev='hd'/>
  </os>
  <features><acpi/><apic/></features>
  <cpu mode='host-passthrough' check='none'/>
  <clock offset='utc'/>
  <on_reboot>restart</on_reboot>
  <devices>
    <emulator>/usr/local/sbin/qemu</emulator>
    <!-- system disk: virtio /dev/vda on the NVMe cache pool.
         install.disk=/dev/vda (common.yaml) pins the OS here, NOT the SATA SSD. -->
    <disk type='file' device='disk'>
      <driver name='qemu' type='raw' cache='none' discard='unmap'/>
      <source file='__DISK_DIR__/__NAME__/system.img'/>
      <target dev='vda' bus='virtio'/>
    </disk>
    <!-- Longhorn data disk: WHOLE passed-through SATA SSD (MX500) → guest /dev/sdb (ATA).
         UserVolumeConfig (!system_disk) mounts it at /var/mnt/longhorn. -->
    <disk type='block' device='disk'>
      <driver name='qemu' type='raw' cache='none' io='native' discard='unmap'/>
      <source dev='__SATA_BYID__'/>
      <target dev='sdb' bus='sata'/>
    </disk>
    <!-- Talos install ISO (first boot only). Eject after Talos installs to vda;
         the eject command is printed by define-vms.sh. -->
    <disk type='file' device='cdrom'>
      <driver name='qemu' type='raw'/>
      <source file='__DISK_DIR__/talos-metal-amd64.iso'/>
      <target dev='sda' bus='sata'/>
      <readonly/>
    </disk>
    <interface type='bridge'>
      <source bridge='__BRIDGE__'/>
      <model type='virtio'/>
    </interface>
    <channel type='unix'>
      <target type='virtio' name='org.qemu.guest_agent.0'/>
    </channel>
    <serial type='pty'><target port='0'/></serial>
    <console type='pty'><target type='serial' port='0'/></console>
    <video><model type='qxl'/></video>
    <graphics type='vnc' port='-1' autoport='yes' listen='0.0.0.0'/>
    <memballoon model='virtio'/>
  </devices>
</domain>
