# ─── clusters/talos/cluster.env ───────────────────────────────────────────────
# SINGLE SOURCE OF TRUTH for every placeholder in this bundle.
# Every script sources this file. Nothing else needs editing.
#
# Cross-checked 2026-06-13 against:
#   vanfreckle-platform/talos-parallel-cluster-build-guide-2026-06-05.md (v3.2)
#     + "SATA SSD Longhorn storage — ADDENDUM 2026-06-13"
#     + "UPDATE 2026-06-13b — third Longhorn replica on cp2 NVMe"
# Storage topology is now replica-3 across worker1 + cp3 + cp2 (cp1 storage-free).

# ── Versions (LOCKED 2026-06-13, Option A — do not bump without re-reading the guide) ──
TALOS_VERSION="v1.13.3"          # latest STABLE 1.13.x (v1.14 is alpha only)
KUBERNETES_VERSION="v1.35.4"     # 🛑 PINNED via --kubernetes-version in gen-configs.sh.
                                 #    Do NOT inherit Talos 1.13.3's BUNDLED k8s 1.36 —
                                 #    it is ABOVE Longhorn 1.11.x's tested ceiling (1.35).
                                 #    This is the single most important value in the file.
LONGHORN_VERSION="1.11.2"        # latest 1.11.x — NOT 1.12.0; tested k8s 1.32–1.35
CNPG_VERSION="1.29.1"            # HARD MINIMUM: fixes CVE-2026-44477 (9.4). Never older.
PG_MAJOR="18"                    # CNPG default operand series

# ── Image Factory (recorded 2026-06-13; bakes iscsi-tools + util-linux-tools + qemu-guest-agent) ──
# VERIFY at node-up: talosctl get extensions
SCHEMATIC_ID="e187c9b90f773cd8c84e5a3265c5554ee787b2fe67b508d9f955e90e7ae8c96c"
INSTALL_IMAGE="factory.talos.dev/installer/${SCHEMATIC_ID}:${TALOS_VERSION}"

# ── Cluster identity ─────────────────────────────────────────────────────────
CLUSTER_NAME="cartarch-prod"     # matches guide Phase 4 (`talosctl gen config cartarch-prod ...`)
VIP="10.42.1.64"                 # API-server VIP — CONTROL-PLANE interfaces only (NOT worker1)
K8S_ENDPOINT="https://${VIP}:6443"

# ── Network (10.42.1.0/24 — same LAN as the old cluster's 10.42.1.50 ingress) ─
# 🅵 CONFIRM gateway + DNS against your LAN before apply. Defaults below are the
#    conventional .1 for a /24 — plausible, NOT verified. They only affect the
#    RENDERED node configs, not offline patch validation.
GATEWAY="10.42.1.1"              # ASSUMPTION — confirm pfSense/router LAN IP
NETMASK_CIDR="24"
NAMESERVER="10.42.1.1"           # ASSUMPTION — confirm resolver (pfSense most likely)
UNRAID_BRIDGE="br0"              # confirm bridge name on Unraid

# ── Pod / service CIDRs: DELIBERATELY using Talos defaults — NO override ──────
#    pods 10.244.0.0/16 · services 10.96.0.0/12 (Talos/kubeadm-canonical).
#    The ABSENCE of a clusterNetwork override in the patches / gen-configs.sh is
#    INTENTIONAL, not an oversight (owner decision 2026-06-14):
#    - No collision with LAN 10.42.1.0/24 (pods are 10.244.*, not the k3s-default
#      10.42.* that the devsecops Phase-0 finding feared).
#    - MATCHES the live old k3s cluster (also 10.244.0.0/16 / 10.96.0.0/12,
#      verified 2026-06-14). Identical INTERNAL CIDRs across two separate
#      blue-green clusters is safe — internal CIDRs don't route on the LAN; only
#      node/VIP/ingress LAN IPs must differ, and they do (.60–.64 vs old .50–.53).
#    - Matches the CKA exam env. To diverge later, add a clusterNetwork patch at
#      `talosctl gen config` time — see the Talos build guide.

# ── Nodes: 3 control-plane + 1 worker (build guide v3.2) ─────────────────────
# name | static IP | role  (IPs locked by the build constraints 2026-06-13)
NODE1_NAME="cp1";     NODE1_IP="10.42.1.60"; NODE1_ROLE="controlplane"  # bootstrap + VIP holder; STORAGE-FREE
NODE2_NAME="cp2";     NODE2_IP="10.42.1.61"; NODE2_ROLE="controlplane"  # 3rd Longhorn replica on NVMe vdisk
NODE3_NAME="cp3";     NODE3_IP="10.42.1.62"; NODE3_ROLE="controlplane"  # Longhorn replica on SATA 850 EVO
NODE4_NAME="worker1"; NODE4_IP="10.42.1.63"; NODE4_ROLE="worker"        # Longhorn replica on SATA MX500

# ── Storage topology (ADDENDUM + UPDATE 2026-06-13b) ─────────────────────────
# Longhorn numberOfReplicas=3, disks tagged "ssd", diskSelector pins to these 3:
#   worker1 → MX500  SATA SSD, passed through by-id  (healthiest drive → stable node)
#   cp3     → 850 EVO SATA SSD, passed through by-id  (older/past-rated → replace-first, R2-backed)
#   cp2     → ~80 GB vdisk carved from the NVMe cache pool (NOT passthrough)
# cp1 carries NO Longhorn disk and gets NEITHER the UserVolume nor kubelet-mount patch.
LONGHORN_REPLICAS="3"

# ── Disks on the NVMe Cache pool — LOCKED by guide UPDATE 2026-06-13c ─────────
# Sized against the ACTUAL ZFS pool budget — do NOT re-pad these.
VM_DISK_DIR="/mnt/cache/domains/talos"   # CONFIRM cache pool mount path on Unraid
SYSTEM_DISK_GB="15"              # Talos system disk per node (all 4) → NVMe cache pool
CP2_LONGHORN_VDISK_GB="50"       # cp2 ONLY: 3rd-replica vdisk on NVMe
# worker1 + cp3 take a PASSED-THROUGH SATA SSD instead of a vdisk — see vms/ templates.

# ── SATA passthrough by-id (worker1 + cp3) — 🛑 TODO, fill AFTER internal install ──
# The drives are on a USB-SATA bridge RIGHT NOW, which reports a DIFFERENT/unstable id.
# Get the REAL id only after the drive is on an internal SATA port:
#   ls -l /dev/disk/by-id/ | grep -iE 'ata-(CT500MX500|Samsung_SSD_850)'
# define-vms.sh REFUSES to define worker1/cp3 while these are the TODO sentinel.
WORKER1_SATA_BYID="/dev/disk/by-id/ata-CT500MX500SSD1_2202E5FB9567"            # MX500  → worker1
CP3_SATA_BYID="/dev/disk/by-id/ata-Samsung_SSD_850_EVO_500GB_S2RANX0HA18036N"  # 850EVO → cp3

# ── VM sizing — guide Phase-0 RECOMMENDED tier (the 64 GB host now affords it) ──
# CP 6 vCPU / 12 GiB, worker 8 vCPU / 16 GiB. Totals across the 4 VMs:
#   vCPU: 3×6 + 8 = 26 vCPU on the i5-13500's 20 threads → oversubscribed ~1.3×
#         (fine — CP/worker rarely peak together; QEMU time-slices).
#   RAM:  3×12 + 16 = 52 GiB committed; + the live ~14 GiB k3s stack ≈ 66 GiB peak on a
#         64 GiB host. RAM is NOT oversubscribed-safe like vCPU — this assumes the old
#         stack is winding down during the parallel window and ballooning gives slack.
#   🅵 If both clusters must run hot simultaneously, drop CP RAM to 10 GiB first.
CP_RAM_MIB="12288"               # 12 GiB × 3 CP
WORKER_RAM_MIB="16384"           # 16 GiB worker
CP_VCPUS="6"                     # control-plane nodes
WORKER_VCPUS="8"                 # worker

# ── GitOps ───────────────────────────────────────────────────────────────────
# 🅵 Set the real GitHub owner/org. The ArgoCD Application manifests reference this too.
PLATFORM_REPO="https://github.com/CHANGE_ME/vanfreckle-platform.git"
CLUSTER_OVERLAY_PATH="clusters/talos"
